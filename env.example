# Slack Bot Token (starts with xoxb-)
# Get from: api.slack.com/apps > Your App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App Token (starts with xapp-)
# Get from: api.slack.com/apps > Your App > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# OpenAI API Key (starts with sk-)
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Apify API token — optional, enables auto-fetching LinkedIn post content
# when a URL is shared without the post text pasted alongside it.
# Get from: console.apify.com/account/integrations
APIFY_API_TOKEN=

# Apify actor used to fetch LinkedIn posts (username/actor-name form).
# Default targets a public LinkedIn post scraper. Override if you prefer
# a different actor — verify your actor's input schema matches the input key below.
APIFY_LINKEDIN_ACTOR=curious_coder/linkedin-post-scraper

# JSON key the actor expects for the URL list. Most LinkedIn post actors use
# "postUrls" or "urls". Change if your chosen actor uses a different field.
APIFY_LINKEDIN_INPUT_KEY=postUrls
